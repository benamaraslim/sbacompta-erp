{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Démarrer l'ERP",
      "type": "shell",
      "command": "npm run dev",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "starting",
          "endsPattern": "Ready in"
        }
      }
    },
    {
      "label": "Prisma Studio (base de données)",
      "type": "shell",
      "command": "npm run db:studio",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
